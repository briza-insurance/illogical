{
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2021", "DOM"],
    "module": "NodeNext",
    "target": "ES2021",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": "src",
    "declarationDir": "types",
    "declaration": true,
    "isolatedModules": true
  },
  "testMatch": ["**/__test__/**/*.[jt]s?(x)"],
  "include": ["src"],
  "exclude": ["node_modules"]
}
